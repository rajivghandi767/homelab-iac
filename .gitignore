# ==============================================================================
# TIER 1: CRITICAL SECRETS & CREDENTIALS (NEVER COMMIT)
# ==============================================================================
# API Keys, JSON Service Accounts, and localized environment files
secrets/
gcp-credentials.json
*.pem
*.key
*.enc

# Ephemeral UI/API files
.env
.env.*
**/.env
!.env.j2
!.env.example
services/monitoring/alertmanager/config/alertmanager.yml

# Ansible Control Node Safeguards (Mac)
.vault_pass
*.vault_pass
ansible_vault_pass.txt
tmp/

# ==============================================================================
# TIER 2: INFRASTRUCTURE AS CODE STATE (TERRAFORM & ANSIBLE)
# ==============================================================================
# Terraform (The heavy binaries and the plain-text state files)
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
crash.log

# Ansible (Dynamic cache and retries)
.ansible/
*.retry
vault_token

# ==============================================================================
# TIER 3: DISASTER RECOVERY & BACKUPS
# ==============================================================================
# Protects all local tarballs, GPG archives, and logical SQL dumps from Git
backups/*
!backups/.gitkeep
!backups/README.md
*.sql

# ==============================================================================
# TIER 4: HOMELAB SERVICE DATA (DOCKER VOLUMES & LIVE STATE)
# ==============================================================================
# A strict wildcard approach to prevent any stateful container data from leaking
services/*/data/
services/*/db/
services/*/logs/
services/*/config/*.key
services/*/letsencrypt/

# Explicitly named volume mounts (Deviations from standard 'data/' naming)
services/jenkins/jenkins_home/
services/vault/vault_data/
services/vault/vault_logs/
services/core/pihole/etc-pihole/
services/core/pihole/etc-dnsmasq.d/
services/core/portainer_data/
services/database/postgres_dev_data/
services/database/pgadmin_data/
services/monitoring/grafana_data/
services/monitoring/prometheus_data/

# Live configuration directories (Protects live application state on the host)
services/media/jellyfin/config/
services/media/jellyfin/cache/
services/core/unifi-controller/config/

# ==============================================================================
# TIER 5: APPLICATION REPOSITORIES (JENKINS PROVISIONED)
# ==============================================================================
# Jenkins dynamically provisions project folders and deployment manifests 
# from external application repositories. The IaC repo must ignore all of this
# to prevent source-of-truth conflicts.
services/apps/*
!services/apps/.gitkeep

# ==============================================================================
# TIER 6: OS, IDEs & LANGUAGE COMPILERS
# ==============================================================================
# Operating System
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# IDEs & Editor configs
.vscode/
.idea/
*.iml
*.swp
*~

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# Node / JS
node_modules/
npm-debug.log*
yarn-error.log*
dist/
build/

# Database Init Scripts
init-mongo.js