global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'service']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  receiver: 'discord-notifications'
  routes:
  # Critical alerts (Down/Failed) - Ping Immediately
  - receiver: 'discord-critical'
    matchers:
    - severity="critical"
    group_wait: 0s

receivers:
# Standard Notifications (Warnings, Restarts)
- name: 'discord-notifications'
  discord_configs:
  - webhook_url: '{{ monitoring_discord_webhook_url }}'
    send_resolved: true
    title: '{{ if eq .Status "firing" }}⚠️ Warning{{ else }}✅ Resolved{{ end }}: {{ .GroupLabels.alertname }}'
    message: |
      {{ range .Alerts }}
      **Service:** {{ .Labels.service | default .Labels.instance }}
      **Status:** {{ .Status | toUpper }}
      **Description:** {{ .Annotations.description }}
      {{ end }}

# Critical Notifications (Service Down)
- name: 'discord-critical'
  discord_configs:
  - webhook_url: '{{ monitoring_discord_webhook_url }}'
    send_resolved: true
    # Use different colors/titles for immediate visual urgency
    title: '{{ if eq .Status "firing" }}🔥 CRITICAL FAILURE{{ else }}💚 SERVICE RESTORED{{ end }}'
    message: |
       {{ range .Alerts }}
       **Alert:** {{ .Annotations.summary }}
       **Downtime:** {{ .StartsAt | since }}
       **Description:** {{ .Annotations.description }}
       {{ end }}