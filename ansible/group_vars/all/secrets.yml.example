# ==========================================================
#  ANSIBLE VAULT - SECRET ZERO STORE
#  Do not commit the unencrypted version of this file!
# ==========================================================

# --- 1. Cloud & Disaster Recovery ---
gcs_bucket_name: "your-backup-bucket-name"
backup_encryption_passphrase: "YOUR_BACKUP_DECRYPTION_PASSWORD"
gcs_sa_key_json: |
  {
    "type": "service_account",
    "project_id": "your-gcp-project-id",
    "private_key_id": "...",
    "private_key": "-----BEGIN PRIVATE KEY-----\n...",
    "client_email": "backup-bot@your-project.iam.gserviceaccount.com",
    "client_id": "...",
    "auth_uri": "https://accounts.google.com/o/oauth2/auth",
    "token_uri": "https://oauth2.googleapis.com/token"
  }

# --- 2. Core Infrastructure ---
pihole_secure_password: "YOUR_PIHOLE_PASSWORD"

# --- 3. Database & Caching Core ---
postgres_root_user: "postgres_superuser"
postgres_root_password: "postgres_superpassword"

pgadmin_default_email: "dev@rajivwallace.com"
pgadmin_default_password: "YOUR_PGADMIN_PASSWORD"

redis_hosts: "local:redis:6379"
redis_commander_user: "admin"
redis_commander_password: "YOUR_REDIS_PASSWORD"

# --- 4. Observability & Notifications ---
grafana_init_password: "YOUR_GRAFANA_PASSWORD"
monitoring_discord_webhook_url: "YOUR_DISCORD_WEBHOOK"

# Watchtower Webhooks
unifi_watchtower_notification_url: "YOUR_DISCORD_WEBHOOK"
global_watchtower_notification_url: "YOUR_DISCORD_WEBHOOK"

# --- 5. Application Database Credentials ---
# Portfolio App
portfolio_prod_db_user: "portfolio_user"
portfolio_prod_db_password: "portfolio_password"

# Trivia App
trivia_prod_db_user: "trivia_user"
trivia_prod_db_password: "trivia_password"

# Prop & Ferry App
prop_ferry_prod_db_user: "prop_ferry_user"
prop_ferry_prod_db_password: "prop_ferry_password"

# Silicon Valley Trivia App
svt_prod_db_user: "svt_user"
svt_prod_db_password: "svt_password"